# ProofCast — LIVE test configuration.
# Copy this file to `.env` (which is git-ignored) and fill in REAL values.
# Then run:  npm run test:live
# Any section left blank is skipped — you can enable only the parts you have.

# Master switch: live tests only run when this is exactly "1".
PROOFCAST_LIVE=1

# --- AI provider (the model is NEVER pre-chosen — you set it) ---------------
# Anthropic (Claude):
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# ...or OpenAI / Codex / any OpenAI-compatible endpoint:
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=
# Optional explicit selection (else auto-detected from whichever key is set):
# PROOFCAST_AI_PROVIDER=anthropic

# --- Telegram (full pipeline: generate -> record -> send the MP4) -----------
# TELEGRAM_BOT_TOKEN=123456789:AA...   (from @BotFather)
# TELEGRAM_CHAT_ID=                     (send a message to your bot, then read
#                                        the chat id from getUpdates)

# --- Vercel deploy (DESTRUCTIVE: this actually deploys to production) --------
# Requires `vercel login` first. Set the switch AND a deployable project dir.
# PROOFCAST_LIVE_DEPLOY=1
# PROOFCAST_DEPLOY_CWD=C:\path\to\a\deployable\project
