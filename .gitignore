# Dependencies
node_modules/

# Build output
dist/
*.tsbuildinfo

# npm packaging artifact (created by `npm pack`)
*.tgz

# Secrets & local runtime config (created by saveToken())
.proofcast-config.json
.env
.env.*
!.env.example

# ProofCast live session context (debug log, per-session)
proofcast-live.md

# ProofCast video demo artifacts
*.webm
*.mp4
demos/
# …but the landing page's own demo videos are real site content — keep them tracked.
!landing/public/*.mp4
# Shareable proof folders emitted by `--share`
proof-*/
# Proof manifest sidecars written next to a proof video (bind proof ↔ code)
proofcast-proof.json
proofcast-demo-proof.json
playwright-report/
test-results/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Local agent / editor settings (machine-specific)
.claude/settings.local.json
# Local agent/editor scratch config (launch targets, per-machine paths)
.claude/launch.json

# OS / editor cruft
.DS_Store
Thumbs.db
